---
interface Props {
  name: string;
  description: string;
  status: 'live' | 'planning';
  href?: string;
}

const { name, description, status, href } = Astro.props;
---

<div class="work-row">
  <div class="name">
    {href ? <a href={href}>{name}</a> : name}
  </div>
  <div class="desc">{description}</div>
  <div class:list={['status', status]}>{status === 'live' ? 'Live' : 'Planning'}</div>
</div>

<style>
  .work-row {
    display: grid;
    grid-template-columns: 220px 1fr 100px;
    gap: 32px;
    padding: 20px 0;
    border-bottom: 1px solid var(--line);
    align-items: center;
  }

  .name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 17px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .name a { color: var(--text); border: none; }
  .name a:hover { color: var(--cyan); }

  .desc {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--text-dim);
  }

  .status {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 3px;
    border: 1px solid;
    justify-self: start;
  }
  .status.live { color: var(--cyan); border-color: var(--cyan); }
  .status.planning { color: var(--text-faint); border-color: var(--text-faint); }

  @media (max-width: 720px) {
    .work-row { grid-template-columns: 1fr; gap: 8px; }
  }
</style>
