---
interface Props {
  src: string;
  alt: string;
  url: string;
  caption?: string;
  eager?: boolean;
}

const { src, alt, url, caption, eager = false } = Astro.props;
---

<figure class="product-shot">
  <div class="shot-chrome" aria-hidden="true">
    <span class="dot"></span><span class="dot"></span><span class="dot"></span>
    <span class="url">{url}</span>
  </div>
  <img
    src={src}
    alt={alt}
    loading={eager ? 'eager' : 'lazy'}
    decoding="async"
  />
  {caption && <figcaption class="shot-caption">{caption}</figcaption>}
</figure>

<style>
  .product-shot {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 40px 80px -30px rgba(34, 211, 238, 0.18);
    position: relative;
    background: var(--void);
  }
  .product-shot img { display: block; width: 100%; height: auto; }

  .shot-chrome {
    padding: 10px 14px;
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(9, 12, 31, 0.85);
    border-bottom: 1px solid var(--line);
  }
  .shot-chrome .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--line);
  }
  .shot-chrome .url {
    margin-left: 12px;
    font-family: var(--font-sans);
    font-size: 12px;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }

  .shot-caption {
    position: absolute;
    bottom: 12px;
    left: 12px;
    font-family: var(--font-display);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--cyan);
    padding: 6px 10px;
    background: rgba(9, 12, 31, 0.85);
    border: 1px solid var(--line);
    border-radius: 3px;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }
</style>
